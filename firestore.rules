rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'teacher'] &&
             data.createdAt is timestamp &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('schoolName' in data) || data.schoolName is string);
    }

    function isValidClass(data) {
      return data.keys().hasAll(['name', 'teacherId', 'joinCode', 'studentIds', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.teacherId is string &&
             data.joinCode is string && data.joinCode.size() > 0 && data.joinCode.size() < 20 &&
             data.studentIds is list && data.studentIds.size() <= 1000 &&
             data.createdAt is timestamp &&
             (!('studentNames' in data) || data.studentNames is map);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['classId', 'teacherId', 'topicId', 'title', 'createdAt']) &&
             data.classId is string &&
             data.teacherId is string &&
             data.topicId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             data.createdAt is timestamp;
    }

    function isValidTaskCompletion(data) {
      return data.keys().hasAll(['taskId', 'studentId', 'classId', 'score', 'total', 'completedAt']) &&
             data.taskId is string &&
             data.studentId is string &&
             data.classId is string &&
             data.score is number && data.score >= 0 &&
             data.total is number && data.total > 0 &&
             data.completedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /classes/{classId} {
      // Anyone authenticated can read classes to join them, or view their classes
      allow read: if isAuthenticated();
      
      // Only teachers can create classes
      allow create: if isTeacher() && 
                    isValidClass(request.resource.data) && 
                    request.resource.data.teacherId == request.auth.uid;
                    
      // Teachers can update their classes. Students can update to add themselves to studentIds
      allow update: if isAuthenticated() && isValidClass(request.resource.data) &&
                    (
                      (resource.data.teacherId == request.auth.uid) ||
                      (
                        // Student joining: only modifying studentIds and studentNames
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds', 'studentNames']) &&
                        request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1 &&
                        request.auth.uid in request.resource.data.studentIds
                      )
                    );
                    
      allow delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
    }

    match /tasks/{taskId} {
      // Students in the class and the teacher can read
      allow read: if isAuthenticated();
      
      // Only the teacher of the class can create/update/delete
      allow create: if isTeacher() && 
                    isValidTask(request.resource.data) && 
                    request.resource.data.teacherId == request.auth.uid;
                    
      allow update: if isTeacher() && 
                    isValidTask(request.resource.data) && 
                    resource.data.teacherId == request.auth.uid &&
                    request.resource.data.teacherId == request.auth.uid;
                    
      allow delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
    }

    match /taskCompletions/{completionId} {
      // Students can read their own, teachers can read all for their classes
      allow read: if isAuthenticated() && (
                    resource.data.studentId == request.auth.uid ||
                    get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId == request.auth.uid
                  );
                  
      // Students can create their own completions
      allow create: if isAuthenticated() && 
                    isValidTaskCompletion(request.resource.data) &&
                    request.resource.data.studentId == request.auth.uid;
                    
      allow update: if isAuthenticated() && 
                    isValidTaskCompletion(request.resource.data) &&
                    resource.data.studentId == request.auth.uid &&
                    request.resource.data.studentId == request.auth.uid;
    }
  }
}
